# ── Required ───────────────────────────────────────────────────────────────
# Must be a long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# ── Push Notifications (optional) ──────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=

# ── CORS (optional) ────────────────────────────────────────────────────────
# Restrict WebSocket origin in production. Leave blank to allow all (dev only).
ALLOWED_ORIGIN=

# ── TURN Server (optional) ─────────────────────────────────────────────────
# If left blank, falls back to open-relay TURN (for testing only).
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Misc ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
